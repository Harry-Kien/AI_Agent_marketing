# Copy this file to .env for local use. Never commit .env.

# 9Router / OpenAI-compatible AI gateway for Telegram agents.
# NINE_ROUTER_ENABLED=true
# NINE_ROUTER_API_KEY=
# NINE_ROUTER_BASE_URL=http://localhost:20128/v1
# NINE_ROUTER_MODEL=cx/gpt-5.4-mini
# NINE_ROUTER_TIMEOUT_MS=30000
# NINE_ROUTER_MAX_RETRIES=1

# Telegram-first demo command surface.
# Create six bots with @BotFather, add them to one private demo group, then fill these.
# TELEGRAM_MANAGER_BOT_TOKEN=
# TELEGRAM_MARKET_RADAR_BOT_TOKEN=
# TELEGRAM_CONTENT_CREATOR_BOT_TOKEN=
# Internal key retained for compatibility; configure this with @kien_content_creator1_bot.
# TELEGRAM_CREATIVE_PRODUCTION_BOT_TOKEN=
# TELEGRAM_PERFORMANCE_BRAND_BOT_TOKEN=
# TELEGRAM_PAGE_GROWTH_BOT_TOKEN=
# TELEGRAM_GROUP_ID=
# OPERATOR_TELEGRAM_USER_ID=
# TELEGRAM_RUNTIME_STATE_PATH=output/telegram-runtime-state.json

# Meta Graph API. Publishing and auto reply stay disabled until credentials are rotated and reviewed.
# META_PAGE_ID=
# META_PAGE_ACCESS_TOKEN=
# META_GRAPH_API_VERSION=v23.0
# META_PUBLISH_ENABLED=false
# META_AUTO_REPLY_ENABLED=false
